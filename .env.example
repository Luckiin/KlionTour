# ============================================
# KlionTour - Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# ============================================

# URL pública da aplicação
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (banco de dados + auth)
# Crie seu projeto em https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# E-mail (Resend - https://resend.com - gratuito até 3000 emails/mês)
RESEND_API_KEY=re_sua_api_key

# WhatsApp Business (opcional - Twilio ou Z-API)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=

# Chave secreta para sessões (gere com: openssl rand -base64 32)
NEXTAUTH_SECRET=gere_uma_chave_secreta_forte_aqui
NEXTAUTH_URL=http://localhost:3000
